#pragma once

// Diese Datei nach include/secrets.h kopieren und WLAN-Zugangsdaten eintragen.
// include/secrets.h ist per .gitignore vom Repository ausgeschlossen.
//
// Bleiben die Werte leer / fehlt die Datei, startet das Gerät als Access Point
// ("itec-fan-controller") und das Webinterface ist unter http://192.168.4.1
// erreichbar.

#define WIFI_SSID "DEIN_WLAN"
#define WIFI_PASSWORD "DEIN_PASSWORT"

// Optional: Zugangsdaten für das Web-OTA-Update.
// Standard, falls nicht gesetzt: admin / fancontrol-ota
#define OTA_USERNAME "admin"
#define OTA_PASSWORD "DEIN_OTA_PASSWORT"
